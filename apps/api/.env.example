PORT=3001
WEB_ORIGIN=http://localhost:3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=aienc

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Required. Generate a long random secret before running the admin security module.
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_SECONDS=43200
ADMIN_PENDING_SESSION_TTL_SECONDS=86400
ADMIN_TRUSTED_DEVICE_TTL_SECONDS=2592000
ADMIN_ACCESS_REQUEST_TTL_SECONDS=86400
ADMIN_ACCESS_REQUEST_RETRY_COOLDOWN_SECONDS=3600

# Keep disabled during normal operation. Enable only for the first controlled root bootstrap.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_SECRET=

# Keep disabled during normal operation. Enable only during an exceptional break-glass recovery.
ADMIN_ROOT_RECOVERY_ENABLED=false
ADMIN_ROOT_RECOVERY_SECRET=
